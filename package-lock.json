{
  "name": "infralynx-platform",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "infralynx-platform",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "^5.8.3"
      }
    },
    "apps/api": {
      "name": "@infralynx/api",
      "version": "0.1.0",
      "dependencies": {
        "@infralynx/config": "*",
        "@infralynx/domain-core": "*",
        "@infralynx/shared": "*"
      }
    },
    "apps/web": {
      "name": "@infralynx/web",
      "version": "0.1.0",
      "dependencies": {
        "@infralynx/config": "*",
        "@infralynx/domain-core": "*",
        "@infralynx/shared": "*"
      }
    },
    "apps/worker": {
      "name": "@infralynx/worker",
      "version": "0.1.0",
      "dependencies": {
        "@infralynx/config": "*",
        "@infralynx/domain-core": "*",
        "@infralynx/shared": "*"
      }
    },
    "node_modules/@infralynx/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@infralynx/config": {
      "resolved": "packages/config",
      "link": true
    },
    "node_modules/@infralynx/domain-core": {
      "resolved": "packages/domain-core",
      "link": true
    },
    "node_modules/@infralynx/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@infralynx/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/@infralynx/worker": {
      "resolved": "apps/worker",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/config": {
      "name": "@infralynx/config",
      "version": "0.1.0"
    },
    "packages/domain-core": {
      "name": "@infralynx/domain-core",
      "version": "0.1.0"
    },
    "packages/shared": {
      "name": "@infralynx/shared",
      "version": "0.1.0"
    }
  }
}
