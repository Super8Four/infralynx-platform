{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@infralynx/config": ["../../packages/config/src/index.ts"],
      "@infralynx/domain-core": ["../../packages/domain-core/src/index.ts"],
      "@infralynx/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../../packages/config" },
    { "path": "../../packages/domain-core" },
    { "path": "../../packages/shared" }
  ]
}
