{
  "name": "infralynx-platform",
  "private": true,
  "version": "0.1.0",
  "description": "InfraLynx platform monorepo foundation",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "node scripts/clean.mjs",
    "lint": "eslint . --ext .ts,.mjs --max-warnings=0",
    "test": "node --test tests/unit/**/*.test.mjs",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
